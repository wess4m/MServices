@model LoginRequestDTO

<form method="post">
    <div class="container border p-4">
        <div class="row text-center p-2">
            <h2>Login</h2>
        </div>
        <div class="row">
            <div class="row">
                <div class="col-12 col-md-6 offset-md-3 pb-2">
                    <input asp-for="Email" class="form-control" placeholder="Email"/>
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
            <div class="col-12 col-md-6 offset-md-3 pb-2">
                <input type="password" asp-for="Password" class="form-control" placeholder="Password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-6 offset-md-3 pb-2">
                <button type="submit" class="form-control btn-success" value="Submit">Login</button>
            </div>
            </div>
    </div>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}